includeConfig "$baseDir/params.config"
workDir = "/users/pr/proteomics/mygit/qcloud2-pipeline-runs"

process {
    executor = 'slurm'
    cache = 'lenient'
    queue = 'genoa64'
    cpus = '1'
    memory = '10G'
    time = '6h'
    scratch = false
    errorStrategy = 'ignore'

    clusterOptions = { task.time <= 3.h ? '--qos=shorter' : 
    (task.time <= 6.h ? '--qos=short' : 
    (task.time <= 12.h ? '--qos=normal' : 
    (task.time <= 24.h ? '--qos=long' : 
    (task.time <= 48.h ? '--qos=vlong' : '--qos=marathon' )))) }

    withLabel: big_mem {
        memory = '60G'  // Updated to match new template
        time = '12h'    // Added from new template
    }

    withLabel: big_cpus {
        cpus = 8
        time = '6h'
        memory = '20G'
    }

    withLabel: little_comp {
        maxForks = 1
        maxRetries = 3
        errorStrategy = { task.attempt < 3 ? 'retry' : 'ignore' }
    }

    withLabel: local {
        executor = "local"
    }

    withLabel: thermoconvert {
        container = 'biocorecrg/thermorawparser:0.2'
    }
}

singularity {
    cacheDir = "$baseDir/singularity"
    enabled = true
}

process.container = 'biocorecrg/qcloud:2.1'
